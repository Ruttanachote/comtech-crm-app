# ============================================
# API Configuration
# ============================================
NUXT_PUBLIC_API_URL=http://api:3333/api/v1

# ============================================
# Keycloak Configuration (Production SSO)
# ============================================
KEYCLOAK_URL=https://sso.clicksbiz.com/
KEYCLOAK_REALM=SCGJWD-Portal
