# ============================================
# Application Configuration
# ============================================
NUXT_PUBLIC_APP_NAME=Cosmic CRM
NODE_ENV=production

# ============================================
# PWA Configuration
# ============================================
NUXT_PUBLIC_PWA_ENABLED=true
